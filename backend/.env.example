# Server
PORT=8001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://admin:secret@localhost:5432/container_mgmt
# Or use individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=container_mgmt
# DB_USER=admin
# DB_PASSWORD=secret

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# OCR Service URL (optional, for scan-image feature)
OCR_SERVICE_URL=http://localhost:8000
