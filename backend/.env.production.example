# Environment variables untuk backend deployment
# Jangan commit file ini ke Git!

# Server Configuration
PORT=8001
NODE_ENV=production

# Database - ganti dengan connection string dari Neon
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# CORS - tambahkan URL frontend Vercel Anda
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://localhost:4173

# OCR Service (optional)
OCR_SERVICE_URL=http://localhost:8000
